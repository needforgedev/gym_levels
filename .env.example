# Supabase project credentials. Copy this file to `.env` (gitignored)
# and paste your real values. Get them from:
#   Supabase dashboard → Project Settings → API → "Project URL" and
#   the "anon / public" (or "publishable") key.
#
# These values are SAFE to ship in the Flutter client — they're
# protected by Row-Level Security on the database side. The dangerous
# one (never put anywhere near the app) is the SERVICE_ROLE key.
#
# How values reach the app:
#   • Local dev — the Makefile reads this `.env` file and translates
#     each line into a `--dart-define=KEY=VAL` flag passed to flutter.
#   • Production / CI — `--dart-define` values come straight from the
#     secret store (GitHub Actions secrets, etc.); `.env` is not used.
#
# `.env` is NOT bundled as a Flutter asset (P0-2), so secrets cannot
# leak into a release APK / IPA via this file.

PROJECT_URL=https://your-project-ref.supabase.co
PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Phone-hash salt (must match the value stored in Supabase Vault as
# `PHONE_HASH_SALT`). The client uses it to hash:
#   1. The user's own phone number, before pushing to public_profiles.
#   2. Every contact's phone number, before sending to find_users_by_phone_hashes.
#
# IMPORTANT: this salt ships embedded in the app (via --dart-define
# at build time). It is NOT a secret in the cryptographic sense — a
# determined attacker who reverses the binary can recover it and
# rebuild rainbow tables. Its real job is making a casual database
# leak less catastrophic, not defending against motivated adversaries.
# See socials_plan.md for the full privacy-model discussion. The
# "server-side salt" copy was rewritten on the Contacts permission
# screen to match this reality (P0-2b, 2026-05-02).
#
# Generate with: openssl rand -hex 32
PHONE_HASH_SALT=your-32-byte-hex-salt-from-openssl-rand-hex-32
