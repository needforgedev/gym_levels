# Supabase project credentials. Copy this file to `.env` (gitignored)
# and paste your real values. Get them from:
#   Supabase dashboard → Project Settings → API → "Project URL" and
#   the "anon / public" (or "publishable") key.
#
# These are SAFE to ship in the Flutter client — they're protected by
# Row-Level Security on the database side. The dangerous one (never
# put in the app) is the SERVICE_ROLE key.

PROJECT_URL=https://your-project-ref.supabase.co
PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Phone-hash salt (must match the value stored in Supabase Vault as
# `PHONE_HASH_SALT`). The client uses it to hash:
#   1. Its own user's phone number, before pushing to public_profiles.
#   2. Every contact's phone number, before sending to find_users_by_phone_hashes.
#
# The salt is bundled into the app, so a determined attacker who reverses
# the binary can rebuild rainbow tables. That's an accepted limitation
# for v1.x.0 — see socials_plan.md §1.5 for the full discussion. The
# salt's main job is making a casual DB leak less catastrophic, not
# defending against motivated adversaries.
#
# Generate with: openssl rand -hex 32
PHONE_HASH_SALT=your-32-byte-hex-salt-from-openssl-rand-hex-32
