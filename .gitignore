# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
build/

# Supabase / socials secrets — never commit these.
# `.env` holds PROJECT_URL + PUBLISHABLE_KEY + PHONE_HASH_SALT and is
# loaded by flutter_dotenv at runtime. `.env.example` IS committed and
# shows the expected shape.
.env
.env.*
!.env.example
*.env.local

# Supabase CLI scratch dir (created if/when we run `supabase start` or
# `supabase db diff` locally). Migrations under `supabase/migrations/`
# stay committed — they're the source of truth.
.supabase/

# Android signing artefacts. Pre-launch we'll generate a release
# keystore; never check it in.
*.jks
*.keystore
key.properties